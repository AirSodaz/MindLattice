{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop window permissions for the local-first MindLattice shell.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    },
    "allow-workspace-open-default",
    "allow-map-get",
    "allow-node-create",
    "allow-node-move",
    "allow-node-update",
    "allow-edge-create",
    "allow-edge-delete",
    "allow-start-plan-get",
    "allow-support-templates-list",
    "allow-support-adopt",
    "allow-support-discard",
    "allow-strategy-cards-list",
    "allow-strategy-experiment-create",
    "allow-attention-session-start",
    "allow-attention-session-close",
    "allow-context-profile-get",
    "allow-context-profile-update",
    "allow-agent-turn-submit",
    "allow-agent-preview-get",
    "allow-agent-preview-accept",
    "allow-agent-preview-reject",
    "allow-agent-preview-revise",
    "allow-agent-memory-list",
    "allow-agent-memory-update",
    "allow-agent-memory-delete",
    "allow-vault-import",
    "allow-vault-export",
    "allow-check-in-create",
    "allow-check-in-list",
    "allow-settings-get-app",
    "allow-settings-test-llm",
    "allow-settings-update-interface",
    "allow-settings-update-llm"
  ]
}
